<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign up for X</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/home.css">
    <style>
        /* RESET & BASE */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: #fff;
            color: #0f1419;
            overflow-x: hidden;
        }

        /* LANDING PAGE LAYOUT */
        .container {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        .column {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        #twitter {
            align-items: center;
            background-color: #fff;
            flex: 1.2;
        }

        #twitter img {
            max-height: 350px;
            width: auto;
        }

        .right-content {
            padding: 36px;
            max-width: 700px;
        }

        #top-logo img {
            height: 45px;
            margin-bottom: 48px;
        }

        h1 strong {
            font-size: 64px;
            font-weight: 900;
            letter-spacing: -1.2px;
            line-height: 1.2;
            display: block;
            margin-bottom: 48px;
        }

        h2 strong {
            font-size: 31px;
            font-weight: 900;
            display: block;
            margin-bottom: 32px;
        }

        /* BUTTONS */
        .btn-wrapper {
            max-width: 300px;
            width: 100%;
        }

        .btn {
            width: 100%;
            height: 40px;
            border-radius: 9999px;
            border: 1px solid #cfd9de;
            background: #fff;
            color: #0f1419;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            cursor: pointer;
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 12px;
            transition: background 0.2s ease;
        }

        .btn:hover { background: #e6e6e6; }
        .btn sup { font-size: 15px; top: 0; font-weight: 600; }

        .btn-black {
            background-color: #0f1419 !important;
            color: #fff !important;
            border: none;
        }
        .btn-black:hover { background-color: #272c30 !important; }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 8px 0;
            color: #0f1419;
            font-size: 15px;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #eff3f4;
        }

        .divider:not(:empty)::before { margin-right: .5em; }
        .divider:not(:empty)::after { margin-left: .5em; }

        /* MODAL OVERLAYS */
        #basicInfo, #otp, #choosePassword, #profilePic, #userName {
            display: none; /* Controlled by your JS */
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.4);
            z-index: 1000;
        }

        /* WRAPPER TO KEEP MODAL CENTERED WHEN JS SETS DISPLAY TO BLOCK */
        .modal-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100%;
            width: 100%;
        }

        .modal {
            width: 100%;
            max-width: 600px;
            min-height: 500px;
            background: #fff;
            border-radius: 16px;
            padding: 0;
            display: flex;
            flex-direction: column;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        /* HEADER */
        .modal-header {
            height: 53px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 0 16px;
        }
        .modal-header b { font-size: 18px; }

        /* MODAL CONTENT */
        .modal-content {
            padding: 0 80px 32px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .modal-content h2 {
            font-size: 31px;
            font-weight: 700;
            margin: 20px 0 30px;
            letter-spacing: -0.5px;
        }

        /* INPUT GROUPS (Floating Labels) */
        .input-group {
            position: relative;
            margin-bottom: 24px;
        }

        .input-group input {
            width: 100%;
            height: 56px;
            border: 1px solid #cfd9de;
            border-radius: 4px;
            padding: 24px 8px 8px;
            font-size: 17px;
            outline: none;
            transition: border 0.2s;
        }

        .input-group label {
            position: absolute;
            top: 18px;
            left: 10px;
            color: #536471;
            font-size: 17px;
            transition: 0.2s ease;
            pointer-events: none;
        }

        .input-group input:focus { border: 2px solid #1d9bf0; }

        .input-group input:focus + label,
        .input-group input:not(:placeholder-shown) + label {
            top: 8px;
            font-size: 13px;
            color: #1d9bf0;
        }
        
        .input-group input:not(:focus):not(:placeholder-shown) + label {
            color: #536471;
        }

        .char-count {
            position: absolute;
            right: 10px;
            top: 8px;
            font-size: 13px;
            color: #536471;
            display: none; /* Hide by default unless focused */
        }
        .input-group input:focus ~ .char-count { display: block; }

        /* DOB SECTION */
        .dob-section h4 { font-size: 15px; font-weight: 700; margin-top: 10px; }
        .dob-section p { font-size: 14px; color: #536471; margin: 4px 0 16px; }
        .dob-section input[type="date"] {
            width: 100%;
            height: 56px;
            border: 1px solid #cfd9de;
            border-radius: 4px;
            padding: 12px;
            font-size: 17px;
            color: #0f1419;
            outline: none;
        }
        .dob-section input[type="date"]:focus { border: 2px solid #1d9bf0; }

        /* NEXT BUTTON IN MODAL */
        .next-btn {
            margin-top: auto; /* Pushes button to bottom */
            width: 100%;
            height: 52px;
            border-radius: 9999px;
            border: none;
            background: #0f1419;
            color: #fff;
            font-size: 17px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s;
        }
        .next-btn:hover { background: #272c30; }

        /* UTILS */
        .text-link {
            color: #1d9bf0;
            font-size: 14px;
            cursor: pointer;
            text-align: right;
        }
        .text-link:hover { text-decoration: underline; }

        @media (max-width: 1000px) {
            #twitter { display: none; }
            .right-content { padding: 20px; max-width: 100%; }
            h1 strong { font-size: 48px; }
            .modal { border-radius: 0; min-height: 100vh; }
            .modal-content { padding: 0 32px 32px; }
        }
