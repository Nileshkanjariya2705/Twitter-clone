.email-inbox {
    width: 100%;
    max-width: 800px;
    height: 400px;
    background: #f4f7f6;
    border: 1px solid #ddd;
    margin: 20px auto;
    font-family: sans-serif;
}

.inbox-header {
    background: #fff;
    padding: 15px;
    font-weight: bold;
    border-bottom: 1px solid #ddd;
}

.email-item {
    padding: 15px;
    background: #fff;
    border-bottom: 1px solid #eee;
    cursor: pointer;
}

.email-item:hover { background: #f9f9f9; }

.email-sender { font-weight: bold; color: #333; }
.email-subject { color: #555; font-size: 0.9em; }

/* Positioning the OTP Modal over the inbox */

#otp{
    position: relative;
}
        
    </style>
</head>
<body>
    
    <!-- LANDING PAGE -->
    <div id="container" class="container">
        <div id="twitter" class="column">
            <!-- twitter logo -->
            <picture class="twitter">
                <img src="/photos/twitter_Logo.png" alt="X Logo">
            </picture>
        </div>
        
        <div class="column right-content">
            <picture id="top-logo">
                <img src="/photos/twitter_Logo.png" alt="X Logo">
            </picture>
            
            <h1><strong>Happening now</strong></h1>
            <h2><strong>Join today.</strong></h2>

            <div class="btn-wrapper">
                <button onclick="window.location.href='/auth/google'" class="btn">
                    <img style="height: 20px; width: 20px;" src="https://img.icons8.com/?size=100&id=17949&format=png&color=000000" alt=""> 
                    <sup><span>Sign up with Google</span></sup>
                </button>

                <button class="btn">
                    <img style="height: 20px; width: 20px;" src="https://img.icons8.com/?size=100&id=95294&format=png&color=000000" alt=""> 
                    <sup><span>Sign up with Apple</span></sup>
                </button>
                
                <div class="divider">or</div>
                
                <button id="createAccount" class="btn btn-black">
                    <strong>Create account</strong>
                </button>
                
                <h4 style="margin-top: 40px; margin-bottom: 15px;">Already have an account?</h4>
                
                <button onclick="window.location.href='/signin'" class="btn" style="color: #1d9bf0;">
                    <strong>Sign in</strong>
                </button>
            </div>
        </div>
    </div>

    <!-- MAIN FORM -->
    <form id="myform">

        <!-- BASIC INFO -->
        <div id="basicInfo">
            <div class="modal-wrapper">
                <div class="modal">
                    <div class="modal-header">
                        <b>X</b>
                    </div>
                    <div class="modal-content">
                        <h2>Create your account</h2>

                        <div class="input-group">
                            <input type="text" id="name" name="userFullName" placeholder=" " maxlength="50">
                            <label>Name</label>
                            <span class="char-count" id="counter">0 / 50</span>
                        </div>

                        <div class="input-group" id="email">
                            <input type="email" id="userEmail" onblur="checkEmail(this.value)" name="identifier" placeholder=" ">
                            <label>Email</label>
                        </div>
                        
                        <div class="input-group" id="phoneNumber" style="display: none;">
                            <input type="text" id="userPhoneNumber" placeholder=" ">
                            <label>Phone</label>
                        </div>
                        
                        <p class="text-link" id="change">Use phone instead</p>

                        <div class="dob-section">
                            <h4>Date of birth</h4>
                            <p>This will not be shown publicly. Confirm your own age.</p>
                            <input type="date" name="userDateOfBirth" id="">
                        </div>

                        <input type="button" class="next-btn" id="submitBasicInfo" value="Next">
                    </div>
                </div>
            </div>
        </div>

        <!-- OTP VERIFICATION -->
       <!-- Your Original Popup Box -->
    <div id="otp">

          <div style="width: 50%;" class="email-inbox">
        <div class="inbox-header">Inbox (1)</div>
        <div class="email-item active" id="openEmail">
            <div class="email-sender">Support Team</div>
            <div class="email-subject">Your Verification Code</div>
            <div class="email-preview">Your code is <span id="showOtp"></span></div>
        </div>
    </div>

        <div class="modal-wrapper">
            <div class="modal">
                <div class="modal-header">
                    <b>X</b>
                </div>
                <div class="modal-content">
                    <h2>We sent you a code</h2>
                    <p id="msg" style="margin-bottom: 10px;">Enter the code sent to your email.</p>
                    
                        <div style="display: none;" class="input-group">
                            <input type="text" id="otpId" name="otpId" placeholder=" " maxlength="50">
                            <label>OTP ID</label>
                        </div>

                        <div class="input-group">
                            <input type="text" name="otp_hash" placeholder=" " maxlength="50">
                            <label>Verification Code</label>
                        </div>
                    
                    <p class="text-link" id="resend">Didn't receive email?</p>
                    <input type="button" class="next-btn" id="submitOtp" value="Next">
                </div>
            </div>
        </div>
    </div>
</div>

        <!-- PASSWORD -->
        <div id="choosePassword">
            <div class="modal-wrapper">
                <div class="modal">
                    <div class="modal-header">
                        <b>X</b>
                    </div>
                    <div class="modal-content">
                        <h2>You'll need a password</h2>
                        <p style="color: #536471; font-size: 15px; margin-bottom: 20px;">Make sure it’s 8 characters or more.</p>

                        <div class="input-group">
                            <input type="password" id="userPassword" name="userPassword" placeholder=" " maxlength="50">
                            <label>Password</label>
                            <p style="color: red;" id="ePassword"></p>
                        </div>
                        
                        <input type="button" class="next-btn" id="submitPassword" value="Next">
                    </div>
                </div>
            </div>
        </div>

        <!-- PROFILE PIC -->
        <div id="profilePic">
            <div class="modal-wrapper">
                <div class="modal">
                    <div class="modal-header">
                        <b>X</b>
                    </div>
                    <div class="modal-content">
                        <h2>Pick a profile picture</h2>
                        <p style="color: #536471; font-size: 15px; margin-bottom: 20px;">Have a favorite selfie? Upload it now.</p>

                        <div class="input-group">
                            <input type="file" name="userProfilePic" style="padding: 15px 12px; height: auto;">
                        </div>

                        <input type="button" class="next-btn" id="submitProfilePic" value="Next">
                    </div>
                </div>
            </div>
        </div>

        <!-- USERNAME -->
        <div id="userName">
            <div class="modal-wrapper">
                <div class="modal">
                    <div class="modal-header">
                        <b>X</b>
                    </div>
                    <div class="modal-content">
                        <h2>What should we call you?</h2>
                        <p style="color: #536471; font-size: 15px; margin-bottom: 20px;">Your @username is unique. You can always change it later.</p>

                        <div class="input-group">
                            <input type="text" id="newName" name="userName" placeholder=" " maxlength="50">
                            <label>Username</label>
                            <p style="color: red;" id="eUserName"></p>
                        </div>
                        
                        <input type="submit" class="next-btn" value="Submit">
                    </div>
                </div>
            </div>
        </div>

    </form>

    <script src="/js/home.js"></script>
    <script>
        let globleOptId=null
        // EXACTLY YOUR JAVASCRIPT - 100% UNTOUCHED
        const container= document.getElementById('container')
        const basicInfo= document.getElementById('basicInfo')
        const otp= document.getElementById('otp')
        const choosePassword= document.getElementById('choosePassword')
        const profilePic= document.getElementById('profilePic')
        const userName= document.getElementById('userName')

        // open basic info popup
        document.getElementById('createAccount').addEventListener('click',(e)=>{
            e.preventDefault();
            
            container.style.display='none'
            basicInfo.style.display='block'
        })

        // open otp popup
        document.getElementById('submitBasicInfo').addEventListener('click',async(e)=>{
            e.preventDefault();
            if(!isValidBasicInfo()) return;
            basicInfo.style.display='none'
            otp.style.display='block'
            
            const identifier=document.getElementsByName('identifier')[0].value.trim();
            console.log(identifier);
            
                try {
                    const res=await fetch("http://localhost:8080/auth/sendOtp",{
                        method:'post',
                        body: new URLSearchParams({identifier:`${identifier}`})
                    })
                    const otpId=await res.json();
                    
                    if(res.ok){
                        document.getElementsByName('otpId')[0].value= otpId.otpId;
                        getOtp(otpId.otpId) 
                    }
                    } catch (error) {
                    throw new Error("email not found");
                    }
        })

        // open password popup
        document.getElementById('submitOtp').addEventListener('click',async(e)=>{
            e.preventDefault();

                const otpId=document.getElementsByName('otpId')[0].value.trim();
                const otp_hash=document.getElementsByName('otp_hash')[0].value.trim();

                

                  const res=await fetch('http://localhost:8080/auth/otpVerification',{
                method:'post',
                body:new URLSearchParams({otpId:otpId,otp_hash:otp_hash})
                })

                const data=await res.json();
                if(!res.ok){
                document.getElementById('msg').innerHTML=`${data}`
                 document.getElementById('msg').style.color='red';
                 return;
                }

            otp.style.display='none'
            choosePassword.style.display='block'
        })

        // open profilePic popup
        document.getElementById('submitPassword').addEventListener('click',(e)=>{
            e.preventDefault();
            const password= document.getElementById('userPassword').value.trim()
            if(!passwordValidation(password)) return;
            choosePassword.style.display='none'
            userName.style.display='block'
        })

          // open username popup
        document.getElementById('submitProfilePic').addEventListener('click',(e)=>{
            e.preventDefault();
            profilePic.style.display='none'
            userName.style.display='block'
        })

        // submit data
        const form =document.getElementById('myform');
        form.addEventListener('submit',async(e)=>{
            e.preventDefault();
            if(!userNameValidation()){
                return false;
            }
            const formData=new URLSearchParams(new FormData(form));
            formData.delete('otp_hash')
            formData.delete('otpId')
            
             const res=await fetch("http://localhost:8080/auth/addUser",{
                method:'post',
                body:new URLSearchParams(formData)
                })
                const data=await res.json();
                if(res.status!='201'){
                throw new Error("data not inserted")
                }else{

                window.location.href='/user/dashboard'
                
                }

        })

