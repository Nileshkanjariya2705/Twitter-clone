<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>otp otpVerification</title>

<style>
/* RESET */
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, Helvetica, sans-serif;
}

body{
  background:#fff;
}

/* OPEN BUTTON PAGE */
.container{
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
}

.open-btn{
  padding:12px 20px;
  border-radius:30px;
  border:none;
  background:#0f1419;
  color:#fff;
  cursor:pointer;
}

/* MODAL */
.modal-overlay{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(91,112,131,0.4);
  display:flex;
  align-items:center;
  justify-content:center;
}

.modal{
  width:600px;
  background:#fff;
  border-radius:16px;
  padding:20px 30px;
}

/* HEADER */
.modal-header{
  display:flex;
  justify-content:center;
  position:relative;
}

.close-btn{
  position:absolute;
  left:0;
  font-size:24px;
  cursor:pointer;
}

/* TITLE */
.modal-content h2{
  font-size:28px;
  margin:20px 0;
}

/* INPUT */
.input-group{
  position:relative;
  margin-bottom:20px;
}

.input-group input{
  width:100%;
  height:56px;
  border:1px solid #cfd9de;
  border-radius:6px;
  padding:18px 12px 6px;
  font-size:16px;
  outline:none;
}

.input-group label{
  position:absolute;
  top:18px;
  left:12px;
  color:#536471;
  font-size:14px;
  transition:0.2s;
}

.input-group input:focus{
  border:2px solid #1d9bf0;
}

.input-group input:focus + label,
.input-group input:not(:placeholder-shown) + label{
  top:6px;
  font-size:12px;
  color:#1d9bf0;
}

/* CHAR COUNT */
.char-count{
  position:absolute;
  right:10px;
  top:8px;
  font-size:12px;
  color:#536471;
}

/* DOB */
.dob-section h4{
  margin-top:10px;
}

.dob-section p{
  font-size:13px;
  color:#536471;
  margin:5px 0 10px;
}

.dob-fields{
  display:flex;
  gap:10px;
}

.dob-fields select{
  flex:1;
  height:50px;
  border-radius:6px;
  border:1px solid #cfd9de;
  padding:0 10px;
  font-size:14px;
}

/* BUTTON */
.next-btn{
  margin-top:30px;
  width:100%;
  height:50px;
  border-radius:30px;
  border:none;
  background:#1d4356;
  color:#fff;
  font-weight:bold;
  cursor:pointer;
}

</style>
</head>

<body>

<div class="container">
  <button class="open-btn" onclick="openModal()">Create account</button>
</div>

<!-- MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal">

    <div class="modal-header">
      <!-- <span class="close-btn" onclick="closeModal()">×</span> -->
      <b>X</b>
    </div>
    <form id="myform" >
    <div class="modal-content">
      <h2> otpVerification</h2>
      <p id="msg"></p>
         <div style="display: none;" class="input-group">
        <input type="text" id="otpId" name="otpId" placeholder=" " maxlength="50">
        <label>OTP</label>
      </div>

      <!-- NAME -->
      <div class="input-group">
        <input type="text" id="name" name="otp_hash" placeholder=" " maxlength="50">
        <label>OTP</label>
        <p id="resend"  style="float: right; cursor: pointer;" >resend</p>
      </div>

      <!-- EMAIL -->
      <!-- <div class="input-group">
        <input type="email" id="email" placeholder=" ">
        <label>Email</label>
      </div> -->

      <!-- DOB -->
      <!-- <div class="dob-section">
        <h4>Date of birth</h4>
        <p>
          This will not be shown publicly. Confirm your own age.
        </p>

        <input type="date" name="" id="">
      </div> -->

      <input  type="submit"  class="next-btn" value="Next" id="nextBtn">
</form>
    </div>
  </div>
</div>

<script>
  const res=JSON.parse(sessionStorage.getItem("user"))
  const user=new Map(res);

  async function sendOtp() {
 
    
    try {
      const res=await fetch("http://localhost:8080/auth/sendOtp",{
        method:'post',
        body: new URLSearchParams({identifier:`${user.identifier}`})
      })

      const data=await res.json()
      if(!res.ok){
        document.getElementById('msg').innerHTML=`${data}`
        document.getElementById('msg').style.color='red'
      }else{
        document.getElementById('otpId').value=`${data.otpId}`
        document.getElementById('msg').innerHTML=`${data.msg}`
        document.getElementById('msg').style.color='green'

        
      }
    } catch (error) {
      throw new Error("email not found");
      
    }
  }
  
  

  const form=document.getElementById('myform');
  form.addEventListener('submit',async(e)=>{
    e.preventDefault();
    const otpData=new URLSearchParams(new FormData(form))
    console.log(otpData);
    
    const res=await fetch('http://localhost:8080/auth/otpVerification',{
      method:'post',
      body:otpData
    })

    const data=await res.json();
    if(!res.ok){
      document.getElementById('msg').innerHTML=`${data}`
        document.getElementById('msg').style.color='red'
    }else{
        window.location.href='/register/password' 
    }


  })

  document.getElementById('resend').addEventListener('click',(e)=>{
    sendOtp()
  })
</script>

</body>
</html>