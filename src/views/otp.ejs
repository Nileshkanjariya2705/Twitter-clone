<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Verify Account</title>

<style>
/* RESET */
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, Helvetica, sans-serif;
}

body{
  background:#fff;
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
}

/* CONTAINER */
.container{
  width:600px;
  max-width:90%;
}

/* HEADER */
.header{
  display:flex;
  align-items:center;
  justify-content:center;
  position:relative;
  margin-bottom:30px;
}

.back{
  position:absolute;
  left:0;
  font-size:22px;
  cursor:pointer;
}

.logo{
  font-weight:bold;
  font-size:24px;
}

/* TITLE */
h1{
  font-size:34px;
  font-weight:800;
  margin-bottom:10px;
}

.subtext{
  color:#536471;
  margin-bottom:25px;
}

/* INPUT */
.input-group{
  position:relative;
}

.input-group input{
  width:100%;
  height:60px;
  border:2px solid #1d9bf0;
  border-radius:6px;
  padding:20px 12px 8px;
  font-size:16px;
  outline:none;
}

.input-group label{
  position:absolute;
  top:8px;
  left:12px;
  font-size:13px;
  color:#1d9bf0;
}

/* HELP LINK */
.help{
  margin-top:10px;
  color:#1d9bf0;
  font-size:14px;
  cursor:pointer;
}

/* BUTTON */
.next-btn{
  margin-top:50px;
  width:100%;
  height:50px;
  border:none;
  border-radius:30px;
  background:#cfd9de;
  color:#fff;
  font-weight:bold;
  cursor:not-allowed;
}

/* ACTIVE BUTTON */
.next-btn.active{
  background:#0f1419;
  cursor:pointer;
}

/* RESPONSIVE */
@media(max-width:500px){
  h1{
    font-size:26px;
  }
}
</style>
</head>

<body>

<div class="container">

  <!-- HEADER -->
  <div class="header">
    <span class="back" onclick="goBack()">←</span>
    <div class="logo">X</div>
  </div>

  <!-- CONTENT -->
  <h1>We sent you a code</h1>
  <p class="subtext">
    Enter it below to verify <b id="emailText">your@email.com</b>.
  </p>

  <!-- INPUT -->
  <div class="input-group">
    <input type="text" id="otp" maxlength="6">
    <label>Verification code</label>
  </div>

  <p class="help">Didn't receive email?</p>

  <!-- BUTTON -->
  <button class="next-btn" id="nextBtn">Next</button>

</div>

<script>
/* BACK */
function goBack(){
  window.history.back();
}

/* OTP VALIDATION */
const otpInput = document.getElementById("otp");
const btn = document.getElementById("nextBtn");

otpInput.addEventListener("input",()=>{
  if(otpInput.value.length === 6){
    btn.classList.add("active");
    btn.disabled = false;
  } else {
    btn.classList.remove("active");
    btn.disabled = true;
  }
});

/* OPTIONAL: PASS EMAIL FROM PREVIOUS PAGE */
const params = new URLSearchParams(window.location.search);
const email = params.get("email");

if(email){
  document.getElementById("emailText").innerText = email;
}
</script>

</body>
</html>