<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - X</title>
    <style>
        :root {
            --twitter-blue: #1d9bf0;
            --border-color: #eff3f4;
            --text-secondary: #536471;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, sans-serif;
            background-color: #757575; /* Dim background */
            margin: 0;
            display: flex; justify-content: center; align-items: center; height: 100vh;
        }

        .modal-container {
            background-color: white;
            width: 100%;
            max-width: 600px;
            min-height: 550px;
            border-radius: 16px;
            padding: 20px 80px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .x-logo { height: 32px; margin-bottom: 20px; }

        .content-wrapper { width: 100%; }

        h1 { font-size: 31px; font-weight: 700; margin: 20px 0 10px 0; color: #0f1419; }

        p.instructions {
            font-size: 15px;
            color: var(--text-secondary);
            margin-bottom: 30px;
            line-height: 20px;
        }

        .input-group {
            position: relative;
            width: 100%;
            margin-bottom: 20px;
        }

        input {
            width: 100%;
            height: 55px;
            border: 1px solid #cfd9de;
            border-radius: 4px;
            padding: 20px 12px 10px 12px;
            font-size: 17px;
            box-sizing: border-box;
            transition: border 0.2s;
        }

        label.floating-label {
            position: absolute;
            left: 12px;
            top: 18px;
            color: var(--text-secondary);
            font-size: 17px;
            transition: all 0.2s;
            pointer-events: none;
        }

        /* Float label up when typing or focused */
        input:focus + label, input:not(:placeholder-shown) + label {
            top: 4px;
            font-size: 13px;
            color: var(--twitter-blue);
        }

        input:focus {
            border: 2px solid var(--twitter-blue);
            outline: none;
        }

        .btn {
            width: 100%;
            height: 45px;
            border-radius: 9999px;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            margin-top: 20px;
            transition: 0.2s;
        }

        .btn-black { background-color: #0f1419; color: white; border: none; }
        .btn-black:hover { background-color: #272c30; }
        .btn-black:disabled { opacity: 0.5; }

        #error-msg { color: #f4212e; font-size: 14px; margin-top: 10px; }
        
        .requirements {
            font-size: 13px;
            color: var(--text-secondary);
            margin: 10px 0;
        }
    </style>
</head>
<body>

<div class="modal-container">
    <img src="/photos/twitter_Logo.png" class="x-logo" alt="X">

    <div class="content-wrapper">
        <h1>Choose a new password</h1>
        <p class="instructions">Make sure your new password is at least 8 characters long and includes a mix of letters, numbers, and symbols.</p>

        <form id="resetForm">
            <!-- Password Field -->
            <div class="input-group">
                <input type="password" id="newPassword" placeholder=" " required minlength="8">
                <label class="floating-label">New password</label>
            </div>

            <!-- Confirm Password Field -->
            <div class="input-group">
                <input type="password" id="confirmPassword" placeholder=" " required minlength="8">
                <label class="floating-label">Confirm password</label>
            </div>

            <div class="requirements" id="req-text">Passwords must match.</div>
            <div id="error-msg"></div>

            <button type="submit" id="submitBtn" class="btn btn-black">Reset password</button>
        </form>
    </div>
</div>

<script>
    const form = document.getElementById('resetForm');
    const newPass = document.getElementById('newPassword');
    const confirmPass = document.getElementById('confirmPassword');
    const errorMsg = document.getElementById('error-msg');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMsg.innerText = "";

        if (newPass.value !== confirmPass.value) {
            errorMsg.innerText = "Passwords do not match.";
            return;
        }

        // Logic to send to your backend
        try {
            const res = await fetch("http://localhost:8080/auth/updatePassword", {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    newPassword: newPass.value 
                }),
                credentials:"include"
                
            });

            if (res.ok) {
                alert("Password changed successfully!");
                window.location.href = '/signin';
            } else {
                const data = await res.json();
                errorMsg.innerText = data.message || "Failed to update password.";
            }
        } catch (err) {
            errorMsg.innerText = "Connection error. Try again.";
        }
    });
</script>

</body>
</html>
