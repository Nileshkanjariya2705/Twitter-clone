<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>user dashboard</title>
    <style>
        .nav{
            width: 100%;
            height: 100px;
            border: 1px solid black;
        }
        .nav img{
            width: 100px;
            height: 100px;
        }


        .home-container {
    display: grid;
    grid-template-columns: 275px 600px 350px;
    gap: 0;
    justify-content: center;
    min-height: 100vh;
}

/* 1. Left Navigation */
.nav-column {
    padding: 10px 20px;
    position: sticky;
    top: 0;
    height: 100vh;
    border-right: 1px solid #eff3f4;
}

.nav-item {
    display: block;
    padding: 12px;
    font-size: 20px;
    text-decoration: none;
    color: black;
    border-radius: 999px;
}

.nav-item:hover { background: #e7e7e8; }
.post-btn {
    width: 90%;
    background: #1d9bf0;
    color: white;
    border: none;
    padding: 15px;
    border-radius: 999px;
    font-weight: bold;
    margin-top: 20px;
}

/* 2. Center Feed */
.feed-column {
    border-right: 1px solid #eff3f4;
}

.feed-header {
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #eff3f4;
}

.feed-tabs {
    display: flex;
    text-align: center;
}

.tab {
    flex: 1;
    padding: 15px;
    cursor: pointer;
}

.tab.active { font-weight: bold; border-bottom: 4px solid #1d9bf0; }

/* 3. Composer & Tweets */
.composer {
    display: flex;
    padding: 15px;
    border-bottom: 1px solid #eff3f4;
}

.mini-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    margin-right: 12px;
}

.composer-input { flex: 1; }
.composer-input input {
    width: 100%;
    border: none;
    font-size: 20px;
    outline: none;
    padding: 10px 0;
}

.tweet {
    display: flex;
    padding: 15px;
    border-bottom: 1px solid #eff3f4;
}

.tweet-actions {
    display: flex;
    justify-content: space-between;
    color: #536471;
    margin-top: 10px;
    max-width: 400px;
}

/* 4. Right Sidebar */
.trends-column {
    padding: 10px 20px;
}

.trends-box {
    background: #f7f9f9;
    border-radius: 16px;
    padding: 15px;
    margin-top: 20px;
}

.trend-item { padding: 10px 0; cursor: pointer; }

.mini-avatar {
    cursor: pointer;
    transition: filter 0.2s;
}

.mini-avatar:hover {
    filter: brightness(90%); /* Slight darken effect on hover */
}
/* Container Spacing & Borders */
.home-container {
    background-color: #ffffff;
    color: #0f1419;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

/* Nav Column Enhancements */
.nav-column {
    padding: 0 12px;
}

.logo {
    font-size: 30px;
    padding: 12px;
    margin-bottom: 4px;
}

.nav-item {
    display: flex;
    align-items: center;
    padding: 12px;
    font-size: 20px;
    text-decoration: none;
    color: #0f1419;
    border-radius: 9999px;
    transition: background 0.2s;
    margin-bottom: 4px;
}

.nav-item:hover {
    background-color: rgba(15, 20, 25, 0.1);
}

.nav-item.active {
    font-weight: 800;
}

/* Feed Header Styling */
.feed-header {
    backdrop-filter: blur(12px);
    background-color: rgba(255, 255, 255, 0.85);
    position: sticky;
    top: 0;
    z-index: 2;
    border-bottom: 1px solid #eff3f4;
}

.feed-header h3 {
    padding: 12px 16px;
    margin: 0;
}

.feed-tabs {
    display: flex;
    border-bottom: 1px solid #eff3f4;
}

.tab {
    flex: 1;
    text-align: center;
    padding: 16px;
    font-weight: 600;
    color: #536471;
    cursor: pointer;
    transition: background 0.2s;
}

.tab:hover {
    background-color: rgba(15, 20, 25, 0.1);
}

.tab.active {
    color: #0f1419;
    position: relative;
}

.tab.active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 4px;
    background-color: #1d9bf0;
    border-radius: 9999px;
}

/* Composer Fixes */
.composer {
    padding: 16px;
    display: flex;
    border-bottom: 1px solid #eff3f4;
}

.mini-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    margin-right: 12px;
}

.composer-input {
    flex: 1;
}

.composer-input input {
    width: 100%;
    border: none;
    font-size: 20px;
    outline: none;
    padding: 12px 0;
}

.composer-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 12px;
    border-top: 1px solid #eff3f4;
}

.icons {
    color: #1d9bf0;
    cursor: pointer;
    font-size: 18px;
    gap: 15px;
    display: flex;
}

/* Search Bar & Trends */
.search-bar {
    padding: 6px 16px;
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 2;
}

#myForm {
    background-color: #eff3f4;
    border-radius: 9999px;
    padding: 10px 20px;
    display: flex;
    align-items: center;
}

#search {
    background: transparent;
    border: none;
    outline: none;
    flex: 1;
}

.trends-box {
    background-color: #f7f9f9;
    border-radius: 16px;
    margin: 16px;
    padding: 1px 0; /* Prevents margin collapse */
}

.trends-box h4 {
    padding: 12px 16px;
    margin: 0;
}

.trend-item {
    padding: 12px 16px;
    cursor: pointer;
    transition: background 0.2s;
}

.trend-item:hover {
    background-color: rgba(0, 0, 0, 0.03);
}

/* Buttons */
.post-btn, .small-post-btn {
    background-color: #1d9bf0;
    color: white;
    border: none;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
}

.post-btn {
    width: 90%;
    padding: 14px;
    border-radius: 9999px;
    margin-top: 16px;
    font-size: 17px;
}

.small-post-btn {
    padding: 8px 16px;
    border-radius: 9999px;
    font-size: 15px;
}

.small-post-btn:disabled {
    opacity: 0.5;
}


    </style>
</head>
<body>
  <!-- <div class="nav">
    <img id="profile" onclick="window.location.href='/user/profile'" src="/photos/images.webp" alt="no image found">
  </div> -->
  <div class="home-container">
    <!-- Left Sidebar: Navigation -->
    <aside class="nav-column">
        <div class="logo">𝕏</div>
        <nav>
            <a href="#" class="nav-item active"> Home</a>
            <a href="#" class="nav-item"> Explore</a>
            <a href="#" class="nav-item"> Notifications</a>
            <a href="#" class="nav-item">Messages</a>
            <a href="/user/profile" class="nav-item"> Profile</a>
            <button  class="post-btn">Post</button>
        </nav>
    </aside>

    <!-- Center Column: The Feed -->
    <main class="feed-column">
        <header class="feed-header">
            <h3>Home</h3>
            <div class="feed-tabs">
                <div class="tab active">For you</div>
                <div class="tab">Following</div>
            </div>
        </header>

        <!-- Tweet Composer -->
        <div class="composer">
            <form action="/user/addTweet" enctype="multipart/form-data" method="post">
            <img src="avatar.jpg" class="mini-avatar">
            <div class="composer-input">
                <input type="text" name="tweetText"  placeholder="What is happening?!">
                <div class="composer-actions">
                    <div class="icons"><input name="photos" type="file"></div>
                    <button class="small-post-btn" >Post</button>
                </div>
            </div>
            </form>
        </div>

        <div id="tweets" style="cursor: pointer;">
              <!-- Sample Tweet -->
        <!-- <article class="tweet">
            <img src="avatar2.jpg" class="mini-avatar">
            <div class="tweet-content">
                <div class="tweet-info"><strong>Dev Guru</strong> @devguru · 2h</div>
                <p>Building a UI clone with CSS Grid is surprisingly satisfying! 💻✨</p>
                <div class="tweet-actions">
                    <span>💬 12</span> <span>🔁 5</span> <span>❤️ 45</span> <span>📊 1.2K</span>
                </div>
            </div>
        </article> -->
        </div>
      
    </main>

    <!-- Right Sidebar: Trends & Search -->
    <aside class="trends-column">
        <div class="search-bar">
            <form id="myForm">

                <input id="search" type="text" placeholder="Search"><input type="submit">
            </form>
        </div>
        <section class="trends-box">
            <h4>Trends for you</h4>
            <div class="trend-item">
                <small>Trending in Tech</small>
                <div>#WebDesign</div>
                <small>5,234 posts</small>
            </div>
            <div class="trend-item">
                <small>Trending in India</small>
                <div>#Javascript</div>
                <small>10.1K posts</small>
            </div>
        </section>
    </aside>
</div>

<script>
    async function getTweets(value) {
        if(!value){
            value='%'
        }
        try {
            const res=await fetch(`http://localhost:8080/user/getAllTweets?search=${value}`);
            if(!res.ok){
                throw new  Error("not found")
            }
            const data=await res.json();
            console.log(data);
            
            const tweetsContainer = document.getElementById('tweets');
            tweetsContainer.innerHTML=''

// Use lowercase .forEach
if (data.tweets && Array.isArray(data.tweets)) {
    
    data.tweets.forEach(t => {
        const article = document.createElement("article");
        article.setAttribute('class', 'tweet');
        article.innerHTML = `
    <img onclick='window.location.href="/user/profile?userId=${t.userId}"' src="${t.userProfilePicUrl||''}" class="mini-avatar">
    <div class="tweet-main">
        <div class="tweet-header">
            <div class="user-meta">
                <span class="display-name" >${t.userFullName}</span>
                <span class="username">@${t.userName}</span>
                <span class="separator">·</span>
                <span class="timestamp">${Math.floor((new Date()-new Date(t.created_at))/(60*60*1000))} hr ago</span>
            </div>
            <div class="more-options">···</div>
        </div>

        <div class="tweet-body">
            <p>${t.tweetText||'no text found'}</p>
        </div>

        <!-- ADD IMAGE HERE -->
        ${t.mediaUrl ? `
        <div class="tweet-media">
            <img src="/${t.mediaUrl}"  style='width:200px' class="media-attachment">
        </div>
        ` : ''}

        <div class="tweet-actions">
            <div class="action">💬 <span>12</span></div>
            <div class="action"  onclick='retweet(${t.tweetId})' >🔁 <span>${t.reTweet}</span></div>
            <div class="action"  onclick='like(${t.tweetId})'>${t.likeMe===1?'❤️':'🤍'}  <span>${t.likeCount}</span></div>
  
        </div>
    </div>
`;

        
        tweetsContainer.appendChild(article);          
    });
}

            
        } catch (error) {
            console.log("error",error);
            
        }
    }
    getTweets()


    async function like(id){
        try {
            const res=await fetch(`http://localhost:8080/user/likeTweet/${id}`)
            window.location.reload();
        } catch (error) {
            console.log(error);
            
        }
        
    }


        async function retweet(id){
            console.log(id);
            
        try {

            const res=await fetch(`http://localhost:8080/user/reTweet/${id}`);
            const data=await res.json()
            console.log(data);
            
            location.reload();
           
        } catch (error) {
            console.log(error);
            
        }
        
    }



    const form=document.getElementById('myForm');
    form.addEventListener('submit',async(e)=>{
        e.preventDefault();
        const input=document.getElementById('search').value.trim();

        console.log(input);
        
        if(!input){
            return;
        }

        getTweets(input)

    })
</script>

</body>
</html>