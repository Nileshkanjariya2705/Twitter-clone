}

.tab.active {
    color: #0f1419;
    position: relative;
}

.tab.active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 4px;
    background-color: #1d9bf0;
    border-radius: 9999px;
}

/* Composer Fixes */
