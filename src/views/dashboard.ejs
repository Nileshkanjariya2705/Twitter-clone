<script>
    async function getTweets(value) {
        if(!value){
            value='%'
        }
        try {
            const res=await fetch(`http://localhost:8080/user/getAllTweets?search=${value}`);
            if(!res.ok){
                throw new  Error("not found")
            }
            const data=await res.json();
            console.log(data);
            
            const tweetsContainer = document.getElementById('tweets');
            tweetsContainer.innerHTML=''

// Use lowercase .forEach
if (data.tweets && Array.isArray(data.tweets)) {
    
    data.tweets.forEach(t => {
        const article = document.createElement("article");
        article.setAttribute('class', 'tweet');
        article.innerHTML = `
    <img onclick='window.location.href="/user/profile?userId=${t.userId}"' src="${t.userProfilePicUrl||''}" class="mini-avatar">
    <div class="tweet-main">
        <div class="tweet-header">
            <div class="user-meta">
                <span class="display-name" >${t.userFullName}</span>
                <span class="username">@${t.userName}</span>
                <span class="separator">·</span>
                <span class="timestamp">${Math.floor((new Date()-new Date(t.created_at))/(60*60*1000))} hr ago</span>
            </div>
            <div class="more-options">···</div>
        </div>

        <div class="tweet-body">
            <p>${t.tweetText||'no text found'}</p>
        </div>

        <!-- ADD IMAGE HERE -->
        ${t.mediaUrl ? `
        <div class="tweet-media">
            <img src="/${t.mediaUrl}"  style='width:200px' class="media-attachment">
        </div>
        ` : ''}

        <div class="tweet-actions">
           
        <div class="action" onclick="openComments(${t.tweetId})">💬 <span>${t.commentCount||0}</span></div>

        <!-- Comment Modal -->
<!-- Inside the comment-modal in your dashboard -->
<div id="commentModal" class="comment-modal hidden">
    <div class="modal-content">
        <div class="modal-header">
            <span class="close-modal" onclick="closeComments()">&times;</span>
            <h4>Comments</h4>
        </div>
        
        <!-- Reply Indicator (Hidden by default) -->
        <div id="replyIndicator" class="reply-status hidden">
            Replying to <span id="replyingToName"></span>
            <span class="cancel-reply" onclick="cancelReplyMode()">×</span>
        </div>

        <div class="comment-composer">
            <input type="text" id="newCommentText" placeholder="Post your reply">
            <button class="small-post-btn" id="submitCommentBtn" onclick="postComment()">Reply</button>
        </div>

        <div id="commentsList"></div>
    </div>
</div>


            <div class="action"  onclick='retweet(${t.tweetId})' >🔁 <span>${t.reTweet}</span></div>
            <div class="action"  onclick='like(${t.tweetId})'>${t.likeMe===1?'❤️':'🤍'}  <span>${t.likeCount}</span></div>
  
        </div>
    </div>
`;

        
        tweetsContainer.appendChild(article);          
    });
}

            
