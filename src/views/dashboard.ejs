<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>user dashboard</title>
    <style>
        .nav{
            width: 100%;
            height: 100px;
            border: 1px solid black;
        }
        .nav img{
            width: 100px;
            height: 100px;
        }


        .home-container {
    display: grid;
    grid-template-columns: 275px 600px 350px;
    gap: 0;
    justify-content: center;
    min-height: 100vh;
}

/* 1. Left Navigation */
.nav-column {
    padding: 10px 20px;
    position: sticky;
    top: 0;
    height: 100vh;
    border-right: 1px solid #eff3f4;
}

.nav-item {
    display: block;
    padding: 12px;
    font-size: 20px;
    text-decoration: none;
    color: black;
    border-radius: 999px;
}

.nav-item:hover { background: #e7e7e8; }
.post-btn {
    width: 90%;
    background: #1d9bf0;
    color: white;
    border: none;
    padding: 15px;
    border-radius: 999px;
    font-weight: bold;
    margin-top: 20px;
}

/* 2. Center Feed */
.feed-column {
    border-right: 1px solid #eff3f4;
}

.feed-header {
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #eff3f4;
}

.feed-tabs {
    display: flex;
    text-align: center;
}

.tab {
    flex: 1;
    padding: 15px;
    cursor: pointer;
}

.tab.active { font-weight: bold; border-bottom: 4px solid #1d9bf0; }

/* 3. Composer & Tweets */
.composer {
    display: flex;
    padding: 15px;
    border-bottom: 1px solid #eff3f4;
}

.mini-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    margin-right: 12px;
}

.composer-input { flex: 1; }
.composer-input input {
    width: 100%;
    border: none;
    font-size: 20px;
    outline: none;
    padding: 10px 0;
}

.tweet {
    display: flex;
    padding: 15px;
    border-bottom: 1px solid #eff3f4;
}

.tweet-actions {
    display: flex;
    justify-content: space-between;
    color: #536471;
    margin-top: 10px;
    max-width: 400px;
}

/* 4. Right Sidebar */
.trends-column {
    padding: 10px 20px;
}

.trends-box {
    background: #f7f9f9;
    border-radius: 16px;
    padding: 15px;
    margin-top: 20px;
}

.trend-item { padding: 10px 0; cursor: pointer; }

.mini-avatar {
    cursor: pointer;
    transition: filter 0.2s;
}

.mini-avatar:hover {
    filter: brightness(90%); /* Slight darken effect on hover */
}
/* Container Spacing & Borders */
.home-container {
    background-color: #ffffff;
    color: #0f1419;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

/* Nav Column Enhancements */
.nav-column {
    padding: 0 12px;
}

.logo {
    font-size: 30px;
    padding: 12px;
    margin-bottom: 4px;
}

.nav-item {
    display: flex;
    align-items: center;
    padding: 12px;
    font-size: 20px;
    text-decoration: none;
    color: #0f1419;
    border-radius: 9999px;
    transition: background 0.2s;
    margin-bottom: 4px;
}

.nav-item:hover {
    background-color: rgba(15, 20, 25, 0.1);
}

.nav-item.active {
    font-weight: 800;
}

/* Feed Header Styling */
.feed-header {
    backdrop-filter: blur(12px);
    background-color: rgba(255, 255, 255, 0.85);
    position: sticky;
    top: 0;
    z-index: 2;
    border-bottom: 1px solid #eff3f4;
}

.feed-header h3 {
    padding: 12px 16px;
