let activeTweetId = null;
let activeParentCommentId = null; // To track if we are replying to a comment

function replyToComment(commentId, userName) {
    activeParentCommentId = commentId;
    document.getElementById('replyIndicator').classList.remove('hidden');
    document.getElementById('replyingToName').innerText = `@${userName}`;
    document.getElementById('newCommentText').placeholder = "Post your reply";
    document.getElementById('newCommentText').focus();
}

function cancelReplyMode() {
    activeParentCommentId = null;
    document.getElementById('replyIndicator').classList.add('hidden');
    document.getElementById('newCommentText').placeholder = "Post your reply";
}

async function openComments(tweetId) {
    activeTweetId = tweetId;
    const modal = document.getElementById('commentModal');
    modal.classList.remove('hidden');
    
    const list = document.getElementById('commentsList');
    list.innerHTML = "Loading...";
    
    try {
        const res = await fetch(`http://localhost:8080/user/getComments/${tweetId}`);
        const data = await res.json(); // This is the array from the UNION query
        console.log(data);
        
        list.innerHTML = "";
        
        if (data && data.length > 0) {
            data.forEach(c => {
    const isReply = c.type === 'reply';
    
    // Create the "Replying to @username" label if it's a reply
    const replyLabel = isReply ? 
        `<div class="replying-to-label">Replying to <span class="mention">@${c.replyingTo}</span></div>` : '';

    list.innerHTML += `
        <div class="comment-item ${isReply ? 'reply-item' : ''}">
            <img onclick='window.location.href="/user/profile?userId=${c.userId}"' 
                 src="${c.userProfilePicUrl || '/photos/default.png'}" class="comment-avatar">
            <div class="comment-content">
                <div class="comment-meta">
                    <strong>${c.userFullName}</strong> 
                    <span class="handle">@${c.userName} · ${Math.floor((new Date()-new Date(c.created_at))/(1000*60*60))}h ago</span>
                </div>
                
                ${replyLabel} <!-- This maps the reply to the parent user -->

                <p class="comment-text">${c.commentText}</p>
                
                <div class="comment-actions">
                    ${!isReply ? `<span class="action-link" onclick="replyToComment(${c.commentId}, '${c.userName}')">Reply</span>` : ''}
                    <span class="action-link"></span>
                </div>
            </div>
        </div>`;
});

        } else {
            list.innerHTML = "<p style='text-align:center; color:gray;'>No conversations yet.</p>";
        }
    } catch (err) {
        console.error(err);
    }
}


function closeComments() {
    document.getElementById('commentModal').classList.add('hidden');
}

 const postComment= async () => {
    console.log("---------------------------");
     const text = document.getElementById('newCommentText').value;
    if (!text) return;

    // DECIDE WHICH API TO CALL
    const url = activeParentCommentId 
        ? `http://localhost:8080/user/addCommentReplay`   // Your separate API
        : `http://localhost:8080/user/addComment`; // Standard Comment API

    const payload = activeParentCommentId 
        ? { commentId: activeParentCommentId, commentText: text } // Payload for reply
        : { tweetId: activeTweetId, commentText: text };              // Payload for comment

    try {
        const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        
        if (res.ok) {
            document.getElementById('newCommentText').value = "";
            cancelReplyMode();
            openComments(activeTweetId); // Refresh the list
        }
    } catch (err) {
        console.error("Error submitting:", err);
    }
}


async function getUserProfile() {
    try {
        const res=await fetch("http://localhost:8080/user/getUserProfile")
        const data=await res.json();
        if(!res.ok){
            console.log(data);
            
        }
        

        document.getElementById('userProfilePic').src=data.userProfile[0].userProfilePicUrl
        } catch (error) {
        throw new Error(error);
        
    }
}
getUserProfile()

