<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - X</title>
    <style>
        :root {
            --twitter-blue: #1d9bf0;
            --border-color: #eff3f4;
            --text-secondary: #536471;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #757575; /* Dim background */
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        #myform {
            background-color: white;
            width: 100%;
            max-width: 600px;
            min-height: 500px;
            border-radius: 16px;
            padding: 20px 80px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
        }

        #top-logo img {
            height: 32px;
            margin-bottom: 20px;
        }

        .content-wrapper {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: flex-start; /* Left aligned text for instructions */
        }

        h1 {
            font-size: 31px;
            font-weight: 700;
            margin: 20px 0 10px 0;
            color: #0f1419;
        }

        p.instructions {
            font-size: 15px;
            color: var(--text-secondary);
            line-height: 20px;
            margin-bottom: 30px;
        }

        .input-group {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        input {
            width: 100%;
            height: 50px;
            border: 1px solid #cfd9de;
            border-radius: 4px;
            padding: 12px;
            font-size: 17px;
            margin-bottom: 12px;
            box-sizing: border-box;
            transition: border 0.2s;
        }

        input:focus {
            border: 2px solid var(--twitter-blue);
            outline: none;
        }

        .btn {
            width: 100%;
            height: 45px;
            border-radius: 9999px;
            border: 1px solid #cfd9de;
            background: white;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 20px;
            transition: background 0.2s;
        }

        .btn-black {
            background-color: #0f1419;
            color: white;
            border: none;
        }

        .btn-black:hover { background-color: #272c30; }
        .btn-black:disabled { opacity: 0.5; cursor: not-allowed; }

        #error-msg {
            color: #f4212e;
            font-size: 14px;
            margin-top: 10px;
            width: 100%;
            text-align: left;
        }

        .cancel-link {
            margin-top: 20px;
            color: #0f1419;
            text-decoration: none;
            font-size: 15px;
        }

        .cancel-link:hover { text-decoration: underline; }
    </style>
</head>
<body>

<form id="myform">
    <picture id="top-logo">
        <img src="/photos/twitter_Logo.png" alt="X logo">
    </picture>

    <div class="content-wrapper">
        <h1>Find your X account</h1>
        <p class="instructions">Enter the email, phone number, or username associated with your account to change your password.</p>

        <div class="input-group">
            <input type="text" id="userEmail" name="userEmail" placeholder="Email" required>
            <div id="error-msg"></div>
            
            <button type="submit" id="submitBtn" class="btn btn-black">Next</button>
            <a href="/login" class="cancel-link">Cancel</a>
        </div>
    </div>
</form>

<script>
    const form = document.getElementById('myform');
    const errorMsg = document.getElementById('error-msg');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMsg.innerText = ""; // Clear previous errors
        
        const userEmail = document.getElementById('userEmail').value.trim();
        
        try {
            const res = await fetch("http://localhost:8080/auth/forgotPassword", {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userEmail })
            });

            const data = await res.json();

            if (!res.ok) {
                errorMsg.innerText = data.message || "We couldn't find your account.";
            } else {
                // Redirect to an OTP or "Check your email" confirmation page
                window.location.href = `/otp?id=${data.otpId}`;
            }
        } catch (error) {
            errorMsg.innerText = "Something went wrong. Please try again.";
        }
    });
</script>

</body>
</html>
